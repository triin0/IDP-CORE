{
  "name": "bookmark-manager",
  "version": "1.0.0",
  "private": true,
  "description": "A full-stack bookmark manager with tags and user favorites",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=server && npm run build --workspace=client",
    "start": "npm start --workspace=server",
    "db:generate": "npm run db:generate --workspace=server",
    "db:push": "npm run db:push --workspace=server"
  },
  "workspaces": [
    "server",
    "client"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
