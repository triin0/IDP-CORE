NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173

# Database (Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/game_art?schema=public

# Optional: enable remote generation via OpenAI
OPENAI_API_KEY=
# Model for image generation (example for OpenAI Images API)
OPENAI_IMAGE_MODEL=gpt-image-1

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
