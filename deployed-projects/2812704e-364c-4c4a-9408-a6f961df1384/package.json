{
  "name": "bookmark-manager",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:server dev:client",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "build": "npm-run-all build:types build:server build:client",
    "build:types": "tsc -p tsconfig.json -b",
    "build:server": "npm --workspace server run build",
    "build:client": "npm --workspace client run build",
    "start": "npm --workspace server run start",
    "lint": "npm-run-all -p lint:server lint:client",
    "lint:server": "npm --workspace server run lint",
    "lint:client": "npm --workspace client run lint"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3"
  }
}
