modules = ["nodejs-24", "postgresql-16", "python-3.12"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Showroom API (FastAPI)"

[[workflows.workflow]]
name = "Showroom API (FastAPI)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd showroom-api && python3 main.py"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]

[nix]
channel = "stable-25_05"
packages = ["nano"]
